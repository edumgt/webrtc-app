FROM node:20-alpine AS build

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ .
RUN npm run build

FROM node:20-alpine

WORKDIR /app

COPY --from=build /app/dist ./dist
COPY frontend/frontend-server.cjs ./

ENV FRONTEND_HOST=0.0.0.0
ENV FRONTEND_PORT=80
ENV VITE_SIGNAL_URL=
ENV VITE_SIGNAL_PORT=3001

EXPOSE 80
CMD ["node", "frontend-server.cjs"]
