# Frontend (Vite)
# 로컬 Docker: VITE_SIGNAL_URL을 비워두면 브라우저가 ws://localhost:VITE_SIGNAL_PORT 로 자동 연결
# AWS 배포 시: wss://your-load-balancer-url 로 변경
VITE_SIGNAL_URL=
# 브라우저가 접속하는 호스트 포트 (signaling 컨테이너의 호스트 매핑 포트와 일치)
VITE_SIGNAL_PORT=8481
VITE_DEV_PORT=5173
VITE_HMR_HOST=

FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=80

# Signaling server (Node) - 컨테이너 내부 포트
SIGNAL_HOST=0.0.0.0
SIGNAL_PORT=3001
